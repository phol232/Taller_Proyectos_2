# ── Desarrollo (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── E2E (Playwright) — copia a .env y reemplaza con valores reales
E2E_TEST_EMAIL=test@example.com
E2E_TEST_PASSWORD=changeme

# ── E2E Accesibilidad (axe-core) — credenciales por rol ────────
# Cada par es opcional: si no se define, los tests de accesibilidad de ese rol
# se omiten automáticamente (test.skip), no fallan.
E2E_STUDENT_EMAIL=
E2E_STUDENT_PASSWORD=
E2E_COORDINATOR_EMAIL=
E2E_COORDINATOR_PASSWORD=
E2E_TEACHER_EMAIL=
E2E_TEACHER_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# URLs usadas por los tests e2e (opcionales; tienen defaults locales)
# Para escanear el entorno de producción, apunta BASE_URL allí, ej.:
#   BASE_URL=https://horariosu.wankoraep.com
BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080
SOLVER_BASE_URL=http://localhost:8090
SOLVER_INTERNAL_TOKEN=
