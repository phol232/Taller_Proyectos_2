# =====================================
#  Planner UC — Backend Variables
# =====================================

# --- Servidor ---
PORT=8080

# --- Base de Datos PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/horarios_db
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# --- JWT ---
# Generar con: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_openssl_rand_base64_32
JWT_ACCESS_EXP=900        # 15 minutos en segundos
JWT_REFRESH_EXP=604800    # 7 días en segundos

# --- Google OAuth2 ---
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Frontend (CORS / redirect OAuth2) ---
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Cookies ---
# false en desarrollo (HTTP), true en producción (HTTPS)
COOKIE_SECURE=false
