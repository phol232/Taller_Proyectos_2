# =====================================
#  Planner UC — Backend (.env.prod)
#  RENOMBRAR A: .env.prod
#  NUNCA subir este archivo a Git.
# =====================================

# --- Base de Datos PostgreSQL ---
DB_URL=jdbc:postgresql://db:5432/horarios_db
DB_USERNAME=postgres_prod_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA

# --- JWT ---
# Generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_POR_SECRET_GENERADO_CON_OPENSSL
JWT_ACCESS_EXP=900
JWT_REFRESH_EXP=604800

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET

# --- Frontend (URL pública del servidor) ---
FRONTEND_URL=https://tudominio.com
CORS_ALLOWED_ORIGINS=https://tudominio.com

# --- Cookies ---
COOKIE_SECURE=true   # ← true en producción (requiere HTTPS)

# --- SMTP ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=TU_SMTP_USER
SMTP_PASS=TU_SMTP_PASS
SMTP_FROM_EMAIL=noreply@tudominio.com
SMTP_FROM_NAME=Planner UC
