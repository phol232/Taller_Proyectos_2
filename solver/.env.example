SOLVER_DB_DSN=postgresql://<USER>:<PASSWORD>@localhost:5432/horarios_db_prueba

# Tamaño del pool de conexiones
SOLVER_DB_POOL_MIN=1
SOLVER_DB_POOL_MAX=8

# ── Algoritmo ─────────────────────────────────
# Tiempo máximo que el solver puede tardar en ms
SOLVER_DEFAULT_TIME_LIMIT_MS=30000

# ── Logging ──────────────────────────────────
# Nivel: DEBUG | INFO | WARNING | ERROR
SOLVER_LOG_LEVEL=INFO

# Token compartido con el backend para llamadas internas.
# Define el mismo valor en SOLVER_INTERNAL_TOKEN del backend/compose.
SOLVER_INTERNAL_TOKEN=

# ── Definición de turnos (formato HH:MM, 24h) ──
SOLVER_SHIFT_MORNING_START=06:00
SOLVER_SHIFT_MORNING_END=13:00
SOLVER_SHIFT_AFTERNOON_START=13:00
SOLVER_SHIFT_AFTERNOON_END=19:00
SOLVER_SHIFT_EVENING_START=19:00
SOLVER_SHIFT_EVENING_END=22:00

# ── Horarios del estudiante: borradores con hold de cupo ──
# Duración del bloqueo temporal de cupo por borrador (segundos).
SOLVER_STUDENT_HOLD_TTL_SECONDS=120
# Máximo de borradores vivos simultáneos por alumno.
SOLVER_STUDENT_MAX_LIVE_DRAFTS=3
# Cuántas ofertas top-K se barajan para variar entre generaciones.
SOLVER_STUDENT_TOPK_VARIATION=3

# ── Redis cache (opcional) ─────────────────────
SOLVER_REDIS_ENABLED=false
SOLVER_REDIS_HOST=redis
SOLVER_REDIS_PORT=6379
SOLVER_REDIS_DB=0
SOLVER_REDIS_CACHE_TTL_SECONDS=86400
